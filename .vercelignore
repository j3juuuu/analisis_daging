# Vercel Build Config - Exclude unnecessary files

# Version control
.git/
.github/

# Local development
.venv/
venv/
env/
*.pyc
__pycache__/
.pytest_cache/
*.egg-info/

# IDE and OS
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo

# Build and test artifacts
build/
dist/
.coverage
htmlcov/

# Local Flask runtime
instance/
.webassets-cache

# Documentation
docs/
*.md
!README.md

# But always include:
# - templates/
# - static/
# - api/
# - requirements.txt
# - app.py
# - vercel.json
